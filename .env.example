# =============================================
# 工作動態回報系統 — 環境變數設定
# =============================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# =============================================

# 伺服器設定
PORT=3000

# Turso 雲端資料庫（推薦）
# 至 https://turso.tech 免費申請
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# 若不使用 Turso，系統會自動使用本地 SQLite 檔案 (file:reports.db)
# 本地模式 TURSO_AUTH_TOKEN 留空即可。
#
# ⚠️ 用 Docker / docker-compose 時，請改用掛載 volume 的路徑以持久化資料，
#    否則容器重建後資料會遺失（compose 掛載的是 /app/data）：
# TURSO_DATABASE_URL=file:/app/data/reports.db
