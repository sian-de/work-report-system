# =============================================
# 工作動態回報系統 — 環境變數設定
# =============================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env
# =============================================

# 伺服器設定
PORT=3000

# Turso 雲端資料庫（推薦）
# 至 https://turso.tech 免費申請
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_auth_token_here

# 若不使用 Turso，系統會自動使用本地 SQLite 檔案 (file:reports.db)
# 本地模式無需設定上述兩個變數
